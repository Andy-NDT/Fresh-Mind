{
  "name": "fresh-mind",
  "version": "0.1.0",
  "description": "Local desktop journal — thoughts, reflection, life-spheres wheel. Third app of the Fresh line.",
  "author": {
    "name": "Andy NDT",
    "url": "https://andy-ndt.vercel.app/"
  },
  "homepage": "https://andy-ndt.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Andy-NDT/Fresh-Mind.git"
  },
  "bugs": {
    "url": "https://github.com/Andy-NDT/Fresh-Mind/issues"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prep-brain": "node scripts/prep-brain-crop.js",
    "icons": "node scripts/prep-brain-crop.js && electron-icon-builder --input=./resources/braincrop.png --output=./resources/icons-crop --flatten && node scripts/make-tray-icon.js",
    "tray-icon": "node scripts/make-tray-icon.js",
    "dist": "electron-vite build && electron-builder --win",
    "dist:portable": "electron-vite build && electron-builder --win portable"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "auto-launch": "^5.0.6",
    "better-sqlite3": "^12.10.0",
    "emoji-mart": "^5.6.0",
    "node-cron": "^4.2.1",
    "node-window-manager": "^2.2.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.0.1",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^3.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.ndt.freshmind",
    "productName": "Fresh Mind",
    "copyright": "Copyright © 2026 Andy NDT",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icons-crop/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "resources/icons-crop/icons/icon.ico",
      "uninstallerIcon": "resources/icons-crop/icons/icon.ico",
      "installerHeaderIcon": "resources/icons-crop/icons/icon.ico",
      "shortcutName": "Fresh Mind",
      "artifactName": "Fresh-Mind-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Fresh-Mind-Portable-${version}.${ext}"
    }
  }
}
